      "link": null,
      "locked": false,
      "text": "Header:\n* signature        // 4 bytes\n* version          // 4 bytes\n* entry_count      // 4 bytes\n\nIndexEntry:\n* mode             // 4 bytes\n* object_id        // fixed raw bytes\n* path_length      // 2 bytes\n* path_bytes       // variable",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Header:\n* signature        // 4 bytes\n* version          // 4 bytes\n* entry_count      // 4 bytes\n\nIndexEntry:\n* mode             // 4 bytes\n* object_id        // fixed raw bytes\n* path_length      // 2 bytes\n* path_bytes       // variable",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "EHaxGs8TdgBq6fCOXp292",
      "type": "text",
      "x": -3677.5965621183113,
      "y": 3982.2702154418553,
      "width": 302.33978271484375,
      "height": 325,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
