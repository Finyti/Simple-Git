    {
      "id": "9jtNjrN9Doo4DpB07Lx_B",
      "type": "text",
      "x": 5026.855171395393,
      "y": 1256.3231463663656,
      "width": 597.95947265625,
      "height": 125,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
