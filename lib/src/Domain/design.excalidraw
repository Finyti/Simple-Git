      "text": "header =\n    b\"DIRC\" +\n    uint32_be(n) +\n    uint32_be(n)\n\nentry =\n    uint32_be(0o100644) +\n    <README blob raw id> +\n    uint16_be(9) +\n    b\"README.md\"\n\nuncompressed_bytes =\n    header + entry_1 + entry_2",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "header =\n    b\"DIRC\" +\n    uint32_be(n) +\n    uint32_be(n)\n\nentry =\n    uint32_be(0o100644) +\n    <README blob raw id> +\n    uint16_be(9) +\n    b\"README.md\"\n\nuncompressed_bytes =\n    header + entry_1 + entry_2",
      "autoResize": true,
      "lineHeight": 1.25
