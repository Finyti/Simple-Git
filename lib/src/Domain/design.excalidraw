      "seed": 2012831551,
      "version": 373,
      "versionNonce": 478374833,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1775218818901,
      "link": null,
      "locked": false,
      "text": "Repo - An abstraction over DB (filesystem). Allows to make\nsimple, understandable requests without caring how they\nare accomplished. Called by CLI for changes that are not\na part of the doamin (f.e. FS init), ans Domain when data is\nneeded or a result of a core functionality needs internalising.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Repo - An abstraction over DB (filesystem). Allows to make\nsimple, understandable requests without caring how they\nare accomplished. Called by CLI for changes that are not\na part of the doamin (f.e. FS init), ans Domain when data is\nneeded or a result of a core functionality needs internalising.",
      "autoResize": true,
      "lineHeight": 1.25
    },
